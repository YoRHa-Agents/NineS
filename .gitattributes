# Auto-detect text files and normalize line endings
* text=auto

# Source code
*.c     text diff=cpp
*.cc    text diff=cpp
*.cpp   text diff=cpp
*.cxx   text diff=cpp
*.h     text diff=cpp
*.hh    text diff=cpp
*.hpp   text diff=cpp
*.hxx   text diff=cpp
*.java  text diff=java
*.py    text diff=python
*.go    text diff=golang
*.rs    text diff=rust
*.js    text
*.ts    text
*.jsx   text
*.tsx   text
*.json  text
*.yaml  text
*.yml   text
*.xml   text
*.html  text diff=html
*.css   text diff=css
*.scss  text diff=css
*.sql   text
*.sh    text eol=lf
*.bash  text eol=lf

# Documentation
*.md    text diff=markdown
*.txt   text
*.csv   text
LICENSE text

# Config
*.conf        text
*.cfg         text
*.ini         text
*.toml        text
*.properties  text
Makefile      text
CMakeLists.txt text
Dockerfile    text

# Binary files (no diff, no merge, no line-ending normalization)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   text
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
*.bz2   binary
*.7z    binary
*.jar   binary
*.so    binary
*.dylib binary
*.dll   binary
*.exe   binary
*.o     binary
*.a     binary
*.lib   binary
*.whl   binary
*.egg   binary

